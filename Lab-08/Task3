#include <stdio.h>

int main()
{
    int temp[7][3] = {
        {30, 35, 28},
        {31, 36, 29},
        {29, 34, 27},
        {32, 37, 30},
        {33, 38, 31},
        {34, 39, 32},
        {35, 40, 33}
    };

    int i, j;
    int max = temp[0][0];

    for(i = 0; i < 7; i++)
    {
        for(j = 0; j < 3; j++)
        {
            if(temp[i][j] > max)
                max = temp[i][j];
        }
    }

    printf("Highest temperature = %d\n", max);

    printf("\nAverage temperature of each day:\n");

    for(i = 0; i < 7; i++)
    {
        int sum = 0;

        for(j = 0; j < 3; j++)
        {
            sum += temp[i][j];
        }

        printf("Day %d = %.2f\n", i + 1, (float)sum / 3);
    }

    return 0;
}



