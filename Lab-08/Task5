#include <stdio.h>

int main()
{
    int a[5][5];
    int r, c;
    int i, j;

    printf("Enter number of rows (max 5): ");
    scanf("%d", &r);
    printf("Enter number of columns (max 5): ");
    scanf("%d", &c);

    printf("Enter elements of the matrix:\n");
    for(i = 0; i < r; i++)
        for(j = 0; j < c; j++)
            scanf("%d", &a[i][j]);

    int isSquare = 1, isZero = 1, isIdentity = 1, isDiagonal = 1;
    int isScalar = 1, isUpper = 1, isLower = 1;
    int isSymmetric = 1, isSkew = 1;
    int scalarValue = a[0][0];

    if(r != c)
        isSquare = 0;

    for(i = 0; i < r; i++)
    {
        for(j = 0; j < c; j++)
        {
            if(a[i][j] != 0)
                isZero = 0;

            if(i == j)
            {
                if(a[i][j] != 1)
                    isIdentity = 0;
                if(a[i][j] != scalarValue)
                    isScalar = 0;
            }
            else
            {
                if(a[i][j] != 0)
                {
                    isIdentity = 0;
                    isDiagonal = 0;
                    isScalar = 0;
                }
            }

            if(i > j && a[i][j] != 0)
                isUpper = 0;
            if(i < j && a[i][j] != 0)
                isLower = 0;

            if(isSquare)
            {
                if(a[i][j] != a[j][i])
                    isSymmetric = 0;
                if(a[i][j] != -a[j][i])
                    isSkew = 0;
            }
        }
    }

    printf("\nMatrix Types that apply:\n");

    if(isSquare)
        printf("Square Matrix\n");
    else
        printf("Rectangular Matrix\n");

    if(isZero)
        printf("Zero / Null Matrix\n");

    if(isSquare && isIdentity)
        printf("Identity Matrix\n");

    if(isSquare && isDiagonal)
        printf("Diagonal Matrix\n");

    if(isSquare && isScalar)
        printf("Scalar Matrix\n");

    if(isSquare && isUpper)
        printf("Upper Triangular Matrix\n");

    if(isSquare && isLower)
        printf("Lower Triangular Matrix\n");

    if(isSquare && isSymmetric)
        printf("Symmetric Matrix\n");

    if(isSquare && isSkew)
        printf("Skew-Symmetric Matrix\n");

    if(r == 1)
        printf("Row Matrix\n");

    if(c == 1)
        printf("Column Matrix\n");

    return 0;
}
